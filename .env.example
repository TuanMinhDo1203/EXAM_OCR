LOG_LEVEL=INFO

HOST=0.0.0.0
PORT=8000
STREAMLIT_PORT=8501
BACKEND_PORT=8000
FRONTEND_PORT=8501
NGINX_PORT=8080
AUTO_CREATE_DB_SCHEMA=false

DEVICE=auto
MAX_UPLOAD_MB=10

YOLO_MODEL_PATH=backend/models/YOLO/best_phase2_143.pt

RESNET_MODEL_PATH_HOST=../backend/models/Resnet
TROCR_MODEL_PATH_HOST=../backend/models/trocr_handwritten_decoder_only_best_S1

YOLO_CONF=0.6
YOLO_IOU=0.5
YOLO_MIN_CONF=0.25
